{
  "version": 2,
  "name": "sfritrav",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron-generate",
      "schedule": "30 0 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/sitemap.xml",  "dest": "/api/sitemap"  },
    { "src": "/feed.xml",     "dest": "/api/rss-feed" },
    { "src": "/api/(.*)",     "dest": "/api/$1"        },
    { "src": "/home",         "dest": "/",            "status": 301 },
    { "src": "/blog",         "dest": "/",            "status": 301 },
    { "src": "/news",         "dest": "/pages/category.html?cat=india-news" },
    { "src": "/health",       "dest": "/pages/category.html?cat=health"     },
    { "src": "/sports",       "dest": "/pages/category.html?cat=sports"     },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ]
}
