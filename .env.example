# SfriTrav Environment Variables
# Copy this file to .env.local for local development
# In Vercel: Add these via Dashboard → Project Settings → Environment Variables

# ============================================================
# REQUIRED: Groq API Key (for AI article generation — FREE)
# Sign up at: https://console.groq.com
# Free tier: 14,400 requests/day — plenty for 3 articles/day
# ============================================================
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# REQUIRED: Cron Job Secret (protect /api/cron-generate)
# Generate: openssl rand -hex 32  OR  use any random string
# ============================================================
CRON_SECRET=change_me_to_random_64char_string

# ============================================================
# REQUIRED: Article Generation Secret (protect /api/generate-article)
# Used by the cron job to authenticate article generation calls
# ============================================================
ARTICLE_GEN_SECRET=change_me_to_another_random_64char_string

# ============================================================
# OPTIONAL: Google Analytics Measurement ID
# Get from: https://analytics.google.com
# ============================================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================
# OPTIONAL: NewsData.io API Key (for enhanced trending topics)
# Free tier: 200 calls/day at https://newsdata.io
# ============================================================
# NEWSDATA_API_KEY=pub_XXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# SITE CONFIG (usually don't change these)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://sfritrav.com
NODE_ENV=production
